# =========================================
# [ZH] 專案環境變數範本，請複製為 .env 後再依環境修改
# [EN] Project environment template. Copy to .env and adjust per environment.
# =========================================

# [ZH] API 伺服器監聽埠號
# [EN] API server listening port
PORT=3002

# [ZH] Docker 內部服務呼叫 backend 的共用 base URL，提供 frontend proxy 使用
# [EN] Shared backend base URL inside Docker, used by the frontend proxy
BACKEND_INTERNAL_BASE_URL=http://backend_go:3002

# [ZH] 前端呼叫 API 的基底路徑（反向代理情境建議用 /api）
# [EN] Frontend API base URL (use /api when behind reverse proxy)
VITE_API_BASE_URL=/api

# [ZH] 工程模式登入帳號（frontend /engineer 使用）
# [EN] Engineer mode login username (used by frontend /engineer route)
VITE_ENGINEER_USERNAME=engineer

# [ZH] 工程模式登入密碼（frontend /engineer 使用）
# [EN] Engineer mode login password (used by frontend /engineer route)
VITE_ENGINEER_PASSWORD=123123

# =========================================
# PostgreSQL
# =========================================

# [ZH] PostgreSQL 主機名稱（Docker 內通常填服務名）
# [EN] PostgreSQL host (usually service name in Docker network)
PG_HOST=irds_db_postgresql_v1

# [ZH] PostgreSQL 連接埠
# [EN] PostgreSQL port
PG_PORT=5435

# [ZH] PostgreSQL 使用者帳號
# [EN] PostgreSQL username
PG_USER=postgres

# [ZH] PostgreSQL 使用者密碼（正式環境請改成強密碼）
# [EN] PostgreSQL password (use strong secret in production)
PG_PASSWORD=CHANGE_ME

# [ZH] PostgreSQL 資料庫名稱
# [EN] PostgreSQL database name
PG_DB_NAME=sg_tch_v3

# [ZH] 啟動時是否自動執行 golang-migrate（true/false）
# [EN] Run golang-migrate on startup (true/false)
GO_MIGRATE_ON_START=true

# [ZH] 啟動時是否自動維護分區與留存（true/false）
# [EN] Run partition/retention maintenance on startup (true/false)
GO_PARTITION_MAINTAIN_ON_START=true

# [ZH] Raw log 保留天數（超過會刪除舊分區）
# [EN] Raw log retention days (older partitions will be dropped)
GO_RAW_LOG_RETENTION_DAYS=30

# [ZH] Raw log 每日分區向前預建天數
# [EN] Raw log daily partition backfill days
GO_RAW_LOG_PARTITION_BACK_DAYS=1

# [ZH] Raw log 每日分區向後預建天數
# [EN] Raw log daily partition ahead days
GO_RAW_LOG_PARTITION_AHEAD_DAYS=7

# [ZH] Sensor data 每月分區向前預建月數
# [EN] Sensor data monthly partition backfill months
GO_SENSOR_DATA_PARTITION_BACK_MONTHS=1

# [ZH] Sensor data 每月分區向後預建月數
# [EN] Sensor data monthly partition ahead months
GO_SENSOR_DATA_PARTITION_AHEAD_MONTHS=3

# [ZH] 啟動時是否執行基礎資料 seeder（true/false）
# [EN] Run baseline data seeder on startup (true/false)
GO_SEED_ON_START=true

# [ZH] Seeder 醫院名稱
# [EN] Seeder hospital name
GO_SEED_HOSPITAL_NAME=養護中心

# =========================================
# Worker / Queue Tuning
# =========================================

# [ZH] 感測資料寫入 worker 數量
# [EN] Number of workers for sensor data persistence
GO_SENSOR_WORKERS=6

# [ZH] 原始資料寫入 worker 數量
# [EN] Number of workers for raw data persistence
GO_RAW_WORKERS=3

# [ZH] 感測資料批次大小
# [EN] Sensor data batch size
GO_SENSOR_BATCH_SIZE=200

# [ZH] 原始資料批次大小
# [EN] Raw data batch size
GO_RAW_BATCH_SIZE=150

# [ZH] 批次 flush 間隔（毫秒）
# [EN] Batch flush interval in milliseconds
GO_BATCH_INTERVAL_MS=100

# [ZH] 事件佇列容量
# [EN] Event queue capacity
GO_QUEUE_SIZE=10000

# [ZH] 佇列投遞等待逾時（毫秒）
# [EN] Queue offer timeout in milliseconds
GO_QUEUE_OFFER_TIMEOUT_MS=30

# =========================================
# Payload / Buffer Limits
# =========================================

# [ZH] 單筆資料解析緩衝區上限（位元組）
# [EN] Max parser buffer size in bytes
GO_MAX_BUFFER_SIZE=10240

# [ZH] HTTP 請求主體上限（位元組）
# [EN] Max HTTP request body size in bytes
GO_MAX_BODY_BYTES=65536

# =========================================
# Cache / Dedup Settings
# =========================================

# [ZH] 感測快取有效秒數
# [EN] Sensor cache TTL in seconds
GO_SENSOR_CACHE_TTL_SEC=60

# [ZH] 請求去重有效秒數
# [EN] Request dedup TTL in seconds
GO_REQUEST_DEDUP_TTL_SEC=8

# [ZH] 請求去重鍵上限
# [EN] Max request dedup keys
GO_REQUEST_DEDUP_MAX_KEYS=200000

# [ZH] 事件去重有效秒數
# [EN] Event dedup TTL in seconds
GO_EVENT_DEDUP_TTL_SEC=300

# [ZH] 事件去重鍵上限
# [EN] Max event dedup keys
GO_EVENT_DEDUP_MAX_KEYS=500000

# =========================================
# DB Connection Pool
# =========================================

# [ZH] DB 連線池最大開啟連線數
# [EN] Max open DB connections
GO_DB_MAX_OPEN_CONNS=60

# [ZH] DB 連線池最大閒置連線數
# [EN] Max idle DB connections
GO_DB_MAX_IDLE_CONNS=20

# [ZH] DB 連線最大存活時間（秒）
# [EN] DB connection max lifetime in seconds
GO_DB_CONN_MAX_LIFETIME_SEC=300

# [ZH] DB 查詢逾時（秒）；查 7 天全量熱像時需拉長
# [EN] DB query timeout in seconds; increase for full 7-day thermal history
GO_DB_QUERY_TIMEOUT_SEC=120

# [ZH] DB 寫入逾時（秒）
# [EN] DB insert timeout in seconds
GO_DB_INSERT_TIMEOUT_SEC=5

# [ZH] 裝置超過幾秒沒有最新 sensor_datas 就視為離線
# [EN] Mark device offline after this many seconds without latest sensor_datas
GO_DEVICE_OFFLINE_SECONDS=30

# [ZH] HTTP 讀取逾時（秒）
# [EN] HTTP read timeout in seconds
GO_HTTP_READ_TIMEOUT_SEC=5

# [ZH] HTTP 回應寫入逾時（秒）；大型 history/dump 下載需拉長
# [EN] HTTP write timeout in seconds; increase for large history/dump downloads
GO_HTTP_WRITE_TIMEOUT_SEC=300

# [ZH] HTTP idle 逾時（秒）
# [EN] HTTP idle timeout in seconds
GO_HTTP_IDLE_TIMEOUT_SEC=60

# [ZH] HTTP shutdown 等待逾時（秒）
# [EN] HTTP shutdown timeout in seconds
GO_HTTP_SHUTDOWN_TIMEOUT_SEC=10

# [ZH] 是否記錄每一筆 HTTP request（true/false）
# [EN] Log every HTTP request (true/false)
GO_HTTP_LOG_EVERY_REQUEST=true

# [ZH] 是否記錄 request body 內容（true/false）
# [EN] Log request body content (true/false)
GO_HTTP_LOG_REQUEST_BODY=true

# [ZH] request body 最多記錄 bytes，超過會截斷
# [EN] Max bytes logged for request body (truncated when exceeded)
GO_HTTP_LOG_REQUEST_BODY_MAX_BYTES=65536

# [ZH] DB dump API token；空值會停用 /api/admin/db/dump
# [EN] DB dump API token; blank disables /api/admin/db/dump
GO_DB_DUMP_TOKEN=

# =========================================
# mock_go Load Generator
# =========================================

# [ZH] 每秒固定送出的感測器數量（預設 108，對齊 2F/3F mock_sensors）
# [EN] Number of sensors posted per second (default 108, matching 2F/3F mock_sensors)
MOCK_TARGET_SENSORS=108

# [ZH] 每輪送資料的間隔毫秒（1000 = 每秒）
# [EN] Tick interval in milliseconds (1000 = every second)
MOCK_TICK_MS=1000

# [ZH] 熱像溫度點數（預設 768 = 24x32，對齊 MLX90640）
# [EN] Thermal temperature point count (default 768 = 24x32, aligned with MLX90640)
MOCK_TEMPERATURE_POINTS=768

# [ZH] 可選：並行 HTTP worker 數量；未設定時自動等於 MOCK_TARGET_SENSORS
# [EN] Optional: concurrent HTTP worker count; defaults to MOCK_TARGET_SENSORS when unset
# MOCK_WORKERS=108

# [ZH] 單次 HTTP 請求逾時毫秒
# [EN] Single HTTP request timeout in milliseconds
MOCK_HTTP_TIMEOUT_MS=900

# [ZH] 是否每台每秒先送一筆完整有效生命徵象（true/false）
# [EN] Send one complete valid baseline vital-sign payload per sensor every second (true/false)
MOCK_BASELINE_ENABLED=true

# [ZH] 是否啟用碎片/異常情境額外送測（true/false）
# [EN] Enable additional fragmented/corrupted scenario traffic (true/false)
MOCK_SCENARIO_ENABLED=false

# [ZH] 額外情境比例（0-100，只影響額外情境資料，不取代 baseline）
# [EN] Additional scenario injection rate 0-100 (does not replace baseline sends)
MOCK_SCENARIO_RATE=0

# [ZH] 固定上線但離床的 sensor_number 清單
# [EN] Fixed online out-of-bed sensor_number list
MOCK_OUT_OF_BED_SENSORS=0201_01,0203_03,0205_05

# [ZH] 固定離線的 sensor_number 清單；mock_go 不會送這些床
# [EN] Fixed offline sensor_number list; mock_go does not post these beds
MOCK_OFFLINE_SENSORS=0201_02,0203_04,0205_06

# [ZH] 固定上線且在床但生命徵象超標的 sensor_number 清單
# [EN] Fixed online in-bed sensor_number list with abnormal vital signs
MOCK_WARNING_SENSORS=0207_01,0207_03,0209_01
